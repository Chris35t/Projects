        '.text', '.data', '.bss', '.rodata', '.comment',
        '.shstrtab', '.strtab', '.symtab', '.dynstr', '.dynsym',
        '.dynamic', '.plt', '.got', '.gnu.hash', 'GCC:',
    }

    @classmethod
    def categorize(cls, s: str) -> Optional[str]:
        for p in cls.FLAG_RE:
            if p.search(s):
                return "flag_hint"
        for p in cls.CRYPTO_RE:
            if p.search(s):
                return "crypto"
        for p in cls.NETWORK_RE:
            if p.search(s):
                return "network"
        for p in cls.DEBUG_RE:
            if p.search(s):
                return "debug"
        if cls.FORMAT_RE.search(s):
            return "format"
        return None

    @classmethod
    def is_noise(cls, s: str) -> bool:
        if s in cls.NOISE:
            return True
        if len(s) < 4:
            return True
        if all(c in '._-/\\@$' for c in s):
            return True
        if re.fullmatch(r'[0-9a-fA-F]+', s) and len(s) > 20:
            return True
        return False

