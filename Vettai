def detect_fmt(data: bytes) -> str:
    if data[:4] == ELF.MAGIC:
        return 'elf'
    if data[:2] == PE.MAGIC_DOS:
        try:
            pe_off = struct.unpack_from('<I', data, 0x3c)[0]
            if data[pe_off:pe_off + 4] == PE.MAGIC_PE:
                return 'pe'
        except Exception:
            pass
    return 'unknown'


def main():
    ap = argparse.ArgumentParser(
        prog='vettai',
        description='а®өаҜҮа®ҹаҜҚа®ҹаҜҲ вҖ” Professional Binary Recon (ELF + PE)',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  vettai chall
  vettai CrackMe.exe
  vettai --no-color malware.bin
  vettai --min-str 6 crackme
  vettai --json challenge.exe
        """)
    ap.add_argument('binary')
    ap.add_argument('--no-color',  action='store_true')
    ap.add_argument('--min-str',   type=int, default=5, metavar='N')
    ap.add_argument('--no-tips',   action='store_true')
    ap.add_argument('--json',      action='store_true')
    args = ap.parse_args()

    if args.no_color:
        C.disable()

    if not os.path.isfile(args.binary):
        print(f"Error: '{args.binary}' not found")
        sys.exit(1)

    with open(args.binary, 'rb') as f:
        data = f.read()

    fmt = detect_fmt(data)
    if fmt == 'unknown':
        print(f"Error: Unrecognised format. First 16 bytes: {data[:16].hex()}")
        sys.exit(1)

    md5    = hashlib.md5(data).hexdigest()
    sha256 = hashlib.sha256(data).hexdigest()

    Renderer.banner()

    # в”Җв”Җ ELF path в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    if fmt == 'elf':
        try:
            binary = ELFParser(data, args.binary)
        except Exception as e:
            print(f"{C.RED}ELF parse error: {e}{C.RST}")
            sys.exit(1)

        info = BinaryInfo(
            filepath=args.binary, fmt='elf',
            bits=binary.bits, arch=binary.arch,
            entry=binary.entry,
            filesize=len(data), md5=md5, sha256=sha256,
            elf_type=binary.elf_type_str,
        )
        ascii_s = extract_strings(data, args.min_str)
        wide_s  = []
        sus     = StringAnalyzer.analyze(ascii_s, wide_s, binary.offset_to_vaddr)
        cands   = FlagCheckDetector.analyze_elf(binary, sus)
        xkeys   = XORDetector.scan(binary.sections, data)

        Renderer.file_info(info, binary.libraries)
        Renderer.security(binary.security, 'elf')
        Renderer.sections(binary.sections)
        Renderer.strings(sus)
        Renderer.imports(binary.imports, 'elf')
        Renderer.named_functions(binary)
        Renderer.flag_candidates(cands)
        Renderer.xor_keys(xkeys)
        Renderer.entropy(binary.sections)
        if not args.no_tips:
            Renderer.tips(info, binary.security, cands, binary.imports, sus)
        Renderer.summary(info, sus, cands, binary.imports)

    # в”Җв”Җ PE path в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    else:
        try:
            binary = PEParser(data, args.binary)
        except Exception as e:
            print(f"{C.RED}PE parse error: {e}{C.RST}")
            sys.exit(1)

        info = BinaryInfo(
            filepath=args.binary, fmt='pe',
            bits=binary.bits,
            arch=binary.arch,          # вҶҗ now calls PE.MACHINE_NAMES correctly
            entry=binary.image_base + binary.entry,
            filesize=len(data), md5=md5, sha256=sha256,
            pe_type=binary.pe_type_str,
            compile_ts=binary.compile_time,
            linker_ver=f"{binary.linker_major}.{binary.linker_minor}",
            subsystem=binary.subsystem_str,
        )
        ascii_s = extract_strings(data, args.min_str)
        wide_s  = extract_wide_strings(data, args.min_str)
        sus     = StringAnalyzer.analyze(ascii_s, wide_s, binary.offset_to_vaddr)
        cands   = FlagCheckDetector.analyze_pe(binary, sus)
        xkeys   = XORDetector.scan(binary.sections, data)

        Renderer.file_info(info, binary.libraries)
        Renderer.security(binary.security, 'pe')
        Renderer.sections(binary.sections)
        Renderer.strings(sus)
        Renderer.imports(binary.imports, 'pe')
        Renderer.exports(binary.exports)
        Renderer.flag_candidates(cands)
        Renderer.xor_keys(xkeys)
        Renderer.entropy(binary.sections)
        if not args.no_tips:
            Renderer.tips(info, binary.security, cands, binary.imports, sus)
        Renderer.summary(info, sus, cands, binary.imports)

    # в”Җв”Җ JSON dump в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    if args.json:
        import json
        print("\n" + json.dumps({
            "file":    info.filepath,
            "format":  f"{'ELF' if fmt == 'elf' else 'PE'}{info.bits}",
            "arch":    info.arch,
            "entry":   hex(info.entry),
            "md5":     md5,
            "sha256":  sha256,
            "suspicious_strings": [
                {"addr": hex(s.vaddr), "content": s.content, "category": s.category}
                for s in sus
            ],
            "flag_candidates": [
                {"addr": hex(fc.addr), "reason": fc.reason}
                for fc in cands
            ],
            "imports": [i.name for i in binary.imports],
        }, indent=2))


if __name__ == '__main__':
    main()
