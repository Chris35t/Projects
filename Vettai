    def analyze(cls,
                ascii_strings: List[Tuple[int, str]],
                wide_strings:  List[Tuple[int, str]],
                offset_to_vaddr,
                limit: int = 50) -> List[SuspiciousString]:

        results, seen = [], set()
        combined = [(o, s, 'a') for o, s in ascii_strings] + \
                   [(o, s, 'w') for o, s in wide_strings]

        for file_off, s, _ in combined:
            if s in seen or cls.is_noise(s):
                continue
            cat = cls.categorize(s)
            if cat is None:
                continue
            seen.add(s)
            vaddr = offset_to_vaddr(file_off) or 0
            results.append(SuspiciousString(
                file_offset=file_off,
                vaddr=vaddr,
                content=s,
                category=cat,
            ))

        priority = {"flag_hint": 0, "crypto": 1,
                    "network": 2, "debug": 3, "format": 4}
        results.sort(key=lambda x: (priority.get(x.category, 9), x.file_offset))
        return results[:limit]


# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
#  ELF PARSER
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

class ELFParser:
    def __init__(self, data: bytes, filepath: str):
        self.data      = data
        self.filepath  = filepath
        self.sections: List[SectionInfo] = []
        self.imports:  List[ImportEntry]  = []
        self.exports:  List[ExportEntry]  = []
        self.libraries: List[str]         = []
        self.phdrs:    List[dict]         = []
        self.security  = SecurityFlags()

        self._raw_sections: List[dict] = []
        self._raw_symbols:  List[dict] = []
        self._raw_dynsyms:  List[dict] = []

        self._parse_ident()
        self._parse_header()
        self._parse_sections()
        self._parse_phdrs()
        self._parse_symbols()
        self._parse_dynamic()
        self._check_security()

    def _parse_ident(self):
        if self.data[:4] != ELF.MAGIC:
            raise ValueError("Not an ELF")
        self.bits = 64 if self.data[4] == ELF.CLASS64 else 32
        self.le   = self.data[5] == ELF.LSB
        self.ec   = '<' if self.le else '>'

    def _u(self, fmt: str, off: int) -> tuple:
        return struct.unpack_from(self.ec + fmt, self.data, off)

    def _parse_header(self):
        if self.bits == 64:
            f = self._u('HHIQQQIHHHHHH', 16)
        else:
            f = self._u('HHIIIIIHHHHHH', 16)
        (self.e_type, self.e_machine, _,
         self.entry, self.ph_off, self.sh_off,
         self.e_flags, _,
         self.ph_esz, self.ph_num,
         self.sh_esz, self.sh_num, self.sh_strndx) = f

    def _parse_sections(self):
        if self.sh_num == 0 or self.sh_off == 0:
            return
        raw = []
        for i in range(self.sh_num):
            off = self.sh_off + i * self.sh_esz
            if self.bits == 64:
                f = self._u('IIQQQQIIQQ', off)
                name_i, sh_type, sh_flags, sh_addr, sh_off, sh_size, \
                    sh_link, sh_info, _, sh_entsize = f
            else:
                f = self._u('IIIIIIIIII', off)
                name_i, sh_type, sh_flags, sh_addr, sh_off, sh_size, \
                    sh_link, sh_info, _, sh_entsize = f
            raw.append({
                'name_i': name_i, 'type': sh_type, 'flags': sh_flags,
                'addr': sh_addr, 'offset': sh_off, 'size': sh_size,
                'link': sh_link, 'info': sh_info, 'entsize': sh_entsize,
            })

        strtab = raw[self.sh_strndx] if self.sh_strndx < len(raw) else None
        for r in raw:
            name = self._rstr(strtab['offset'] + r['name_i']) \
                   if strtab else f"<{r['name_i']}>"

            is_exec  = bool(r['flags'] & ELF.SHF_EXEC)
            is_write = bool(r['flags'] & ELF.SHF_WRITE)
            is_alloc = bool(r['flags'] & ELF.SHF_ALLOC)

            if   r['type'] == ELF.SHT_NULL:    label = "NULL"
            elif is_exec:                        label = "CODE"
            elif r['type'] == ELF.SHT_NOBITS:  label = "BSS"
            elif r['type'] == ELF.SHT_NOTE:    label = "NOTE"
            elif r['type'] == ELF.SHT_DYNAMIC: label = "DYNAMIC"
            elif r['type'] in (ELF.SHT_SYMTAB, ELF.SHT_DYNSYM): label = "SYMTAB"
            elif r['type'] == ELF.SHT_STRTAB:  label = "STRTAB"
            elif r['type'] in (ELF.SHT_REL, ELF.SHT_RELA): label = "RELOC"
            elif is_alloc:                       label = "DATA"
            else:                                label = "META"

            sec_data = (self.data[r['offset']:r['offset'] + r['size']]
                        if r['type'] != ELF.SHT_NOBITS and r['size'] > 0
                        else b'')

            self.sections.append(SectionInfo(
                name=name, vaddr=r['addr'], offset=r['offset'],
                size=r['size'], label=label,
                writable=is_write, executable=is_exec,
                entropy=shannon_entropy(sec_data),
            ))
            self._raw_sections.append(r)

    def _rstr(self, off: int) -> str:
        try:
            end = self.data.index(b'\x00', off)
            return self.data[off:end].decode('ascii', errors='replace')
        except ValueError:
            return ""

    def _parse_phdrs(self):
        if self.ph_num == 0 or self.ph_off == 0:
            return
        for i in range(self.ph_num):
            off = self.ph_off + i * self.ph_esz
            if self.bits == 64:
                p_type, p_flags, p_offset, p_vaddr, _, p_filesz, p_memsz, _ = \
                    self._u('IIQQQQQQ', off)
            else:
                p_type, p_offset, p_vaddr, _, p_filesz, p_memsz, p_flags, _ = \
                    self._u('IIIIIIII', off)
            self.phdrs.append({
                'type': p_type, 'flags': p_flags,
                'offset': p_offset, 'vaddr': p_vaddr,
                'filesz': p_filesz, 'memsz': p_memsz,
            })

    def _parse_symbols(self):
        for sec, raw in zip(self.sections, self._raw_sections):
            if raw['type'] not in (ELF.SHT_SYMTAB, ELF.SHT_DYNSYM):
                continue
            if raw['entsize'] == 0 or raw['link'] >= len(self.sections):
                continue
            strtab_raw = self._raw_sections[raw['link']]
            num    = raw['size'] // raw['entsize']
            is_dyn = raw['type'] == ELF.SHT_DYNSYM

            for j in range(num):
                off = raw['offset'] + j * raw['entsize']
                if self.bits == 64:
                    name_i, st_info, _, shndx, value, size = \
                        self._u('IBBHQQ', off)
                else:
                    name_i, value, size, st_info, _, shndx = \
                        self._u('IIIBBH', off)
                st_type = st_info & 0xf
                st_bind = st_info >> 4
                try:
                    name = self._rstr(strtab_raw['offset'] + name_i) \
                           if name_i else ""
                except Exception:
                    name = ""

                sym = {'name': name, 'value': value, 'size': size,
                       'type': st_type, 'bind': st_bind, 'shndx': shndx}

                if is_dyn:
                    self._raw_dynsyms.append(sym)
                    if shndx == 0 and name and st_type == 2:
                        self.imports.append(ImportEntry(name=name))
                    elif shndx != 0 and name and st_type == 2 and st_bind == 1:
                        self.exports.append(ExportEntry(name=name, addr=value))
                else:
                    self._raw_symbols.append(sym)

            if not is_dyn:
                self.security.stripped = False

    def _parse_dynamic(self):
        dyn_raw = next((r for r in self._raw_sections
                        if r['type'] == ELF.SHT_DYNAMIC), None)
        if not dyn_raw:
            return
        self.security.static_linked = False

        dynstr_sec = next((s for s in self.sections if s.name == '.dynstr'), None)
        dynstr_raw = next((r for s, r in zip(self.sections, self._raw_sections)
                           if s.name == '.dynstr'), None)
        if not dynstr_raw:
            return

        esz = dyn_raw['entsize'] or (16 if self.bits == 64 else 8)
        for i in range(dyn_raw['size'] // esz):
            off = dyn_raw['offset'] + i * esz
            try:
                d_tag, d_val = self._u('qQ' if self.bits == 64 else 'iI', off)
            except struct.error:
                break
            if d_tag == ELF.DT_NEEDED:
                try:
                    lib = self._rstr(dynstr_raw['offset'] + d_val)
                    if lib:
                        self.libraries.append(lib)
                except Exception:
                    pass

    def _check_security(self):
        for ph in self.phdrs:
            if ph['type'] == ELF.PT_GNU_STACK:
                self.security.nx = not bool(ph['flags'] & ELF.PF_X)
                break

        self.security.pie = (self.e_type == ELF.ET_DYN)

        has_relro    = any(ph['type'] == ELF.PT_GNU_RELRO for ph in self.phdrs)
        has_bind_now = False
        for raw in self._raw_sections:
            if raw['type'] != ELF.SHT_DYNAMIC:
                continue
            esz = raw['entsize'] or (16 if self.bits == 64 else 8)
            for i in range(raw['size'] // esz):
                off = raw['offset'] + i * esz
                try:
                    d_tag, d_val = self._u('qQ' if self.bits == 64 else 'iI', off)
                except struct.error:
                    break
                if d_tag == 24:
                    has_bind_now = True
                if d_tag == 30 and (d_val & 0x1):
                    has_bind_now = True

        self.security.relro = ("Full"    if has_relro and has_bind_now else
                               "Partial" if has_relro else "None")

        all_names = {s['name'] for s in self._raw_symbols + self._raw_dynsyms}
        self.security.canary = bool(
            {'__stack_chk_fail', '__stack_chk_guard'} & all_names)

    def offset_to_vaddr(self, off: int) -> Optional[int]:
        for ph in self.phdrs:
            if ph['type'] == ELF.PT_LOAD:
                if ph['offset'] <= off < ph['offset'] + ph['filesz']:
                    return ph['vaddr'] + (off - ph['offset'])
        return None

    def get_named_funcs(self) -> List[dict]:
        hot_patterns = {'main','check','verify','validate','flag',
                        'encrypt','decrypt','transform','encode',
                        'decode','process','compare','auth','crack',
                        'solve','hash','key','pass','secret'}
        skip = {'deregister_tm_clones','register_tm_clones',
                'frame_dummy','__do_global_dtors_aux',
                '__libc_csu_init','__libc_csu_fini',
                '_init','_fini','_start'}
        result = []
        for sym in self._raw_symbols:
            if sym['type'] != 2 or sym['value'] == 0 or not sym['name']:
                continue
            if sym['name'] in skip:
                continue
            is_hot = any(p in sym['name'].lower() for p in hot_patterns)
            result.append({**sym, 'hot': is_hot})
        result.sort(key=lambda s: s['value'])
        return result

    def resolve_plt(self) -> Dict[str, int]:
        plt_sec = next(
            (s for s in self.sections if s.name in ('.plt', '.plt.got', '.plt.sec')),
            None)
        if not plt_sec:
            return {}

        rela_raw = next(
            (r for s, r in zip(self.sections, self._raw_sections)
             if s.name in ('.rela.plt', '.rel.plt')),
            None)
        if not rela_raw or rela_raw['entsize'] == 0:
            return {}

        result = {}
        num = rela_raw['size'] // rela_raw['entsize']
        for i in range(num):
            off = rela_raw['offset'] + i * rela_raw['entsize']
            try:
                if self.bits == 64:
                    _, r_info = self._u('QQ', off)
                    sym_idx = r_info >> 32
                else:
                    _, r_info = self._u('II', off)
                    sym_idx = r_info >> 8
            except struct.error:
                break
            if sym_idx < len(self._raw_dynsyms):
                name = self._raw_dynsyms[sym_idx]['name']
                if name:
                    result[name] = plt_sec.vaddr + (i + 1) * 16
        return result

    @property
    def arch(self) -> str:
        # в”Җв”Җ uses ELF.MACHINE_NAMES в”Җв”Җ
        return ELF.MACHINE_NAMES.get(self.e_machine,
                                     f"Unknown(0x{self.e_machine:x})")

    @property
    def elf_type_str(self) -> str:
        return ("Executable"            if self.e_type == ELF.ET_EXEC else
                "Shared Object (PIE)"   if self.e_type == ELF.ET_DYN  else
                f"Type(0x{self.e_type:x})")


# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
#  PE PARSER
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

class PEParser:
    def __init__(self, data: bytes, filepath: str):
        self.data       = data
        self.filepath   = filepath
        self.sections:  List[SectionInfo] = []
        self.imports:   List[ImportEntry]  = []
        self.exports:   List[ExportEntry]  = []
        self.libraries: List[str]          = []
        self.security   = SecurityFlags()
        self.image_base = 0
        self.bits       = 32
        self.pe_off     = 0
        self.opt_off    = 0
        self.sec_off    = 0
        self.num_secs   = 0
        self.data_dirs: List[Tuple[int, int]] = []

        self._parse()

    def _u(self, fmt: str, off: int) -> tuple:
        return struct.unpack_from('<' + fmt, self.data, off)

    def _parse(self):
        e_lfanew = self._u('I', 0x3c)[0]
        if self.data[e_lfanew:e_lfanew + 4] != PE.MAGIC_PE:
            raise ValueError("PE signature not found")
        self.pe_off = e_lfanew

        (self.machine, self.num_secs, self.timestamp,
         _sym_off, _num_syms, opt_hdr_sz,
         self.characteristics) = self._u('HHIIIHH', e_lfanew + 4)

        self.opt_off = e_lfanew + 4 + 20
        self.sec_off = self.opt_off + opt_hdr_sz

        self._parse_optional()
        self._parse_sections()
        self._parse_imports()
        self._parse_exports()
        self._check_security()

    def _parse_optional(self):
        magic = self._u('H', self.opt_off)[0]
        self.pe_magic = magic

        if magic == PE.PE32PLUS:
            self.bits       = 64
            self.image_base = self._u('Q', self.opt_off + 24)[0]
            self.entry      = self._u('I', self.opt_off + 16)[0]
            self.subsystem, self.dll_char = self._u('HH', self.opt_off + 68)
            num_dd  = self._u('I', self.opt_off + 92)[0]
            dd_off  = self.opt_off + 96
        else:
            self.bits       = 32
            self.image_base = self._u('I', self.opt_off + 28)[0]
            self.entry      = self._u('I', self.opt_off + 16)[0]
            self.subsystem, self.dll_char = self._u('HH', self.opt_off + 68)
            num_dd  = self._u('I', self.opt_off + 92)[0]
            dd_off  = self.opt_off + 96

        self.linker_major = self._u('B', self.opt_off + 2)[0]
        self.linker_minor = self._u('B', self.opt_off + 3)[0]

        self.data_dirs = []
        for i in range(min(num_dd, 16)):
            rva, sz = self._u('II', dd_off + i * 8)
            self.data_dirs.append((rva, sz))

    def _parse_sections(self):
        for i in range(self.num_secs):
            off      = self.sec_off + i * 40
            raw_name = self.data[off:off + 8]
            name     = raw_name.rstrip(b'\x00').decode('ascii', errors='replace')

            (vsize, rva, raw_sz, raw_off,
             _, _, _, _,
             chars) = self._u('IIIIIIHHI', off + 8)

            is_exec  = bool(chars & PE.SCN_MEM_EXECUTE)
            is_write = bool(chars & PE.SCN_MEM_WRITE)
            is_code  = bool(chars & PE.SCN_CNT_CODE)
            is_uninit= bool(chars & PE.SCN_CNT_UNINIT_DATA)

            label = ("CODE"     if (is_exec or is_code) else
                     "BSS"      if is_uninit             else
                     "DATA (W)" if is_write              else
                     "DATA")

            sec_data = (self.data[raw_off:raw_off + raw_sz]
                        if raw_off and raw_sz else b'')

            self.sections.append(SectionInfo(
                name=name,
                vaddr=self.image_base + rva,
                offset=raw_off,
                size=vsize or raw_sz,
                label=label,
                writable=is_write,
                executable=is_exec,
                entropy=shannon_entropy(sec_data),
            ))

    def _rva_to_offset(self, rva: int) -> Optional[int]:
        for i in range(self.num_secs):
            off = self.sec_off + i * 40
            vsize, sec_rva, raw_sz, raw_off = self._u('IIII', off + 8)
            span = vsize or raw_sz
            if sec_rva <= rva < sec_rva + span:
                return raw_off + (rva - sec_rva)
        return None

    def _read_str(self, off: int, wide: bool = False) -> str:
        try:
            if wide:
                end = off
                while end < len(self.data) - 1:
                    if self.data[end] == 0 and self.data[end + 1] == 0:
                        break
                    end += 2
                return self.data[off:end].decode('utf-16-le', errors='replace')
            else:
                end = self.data.index(b'\x00', off)
                return self.data[off:end].decode('ascii', errors='replace')
        except (ValueError, UnicodeDecodeError):
            return ""

    def _parse_imports(self):
        if len(self.data_dirs) < 2:
            return
        import_rva, _ = self.data_dirs[1]
        if import_rva == 0:
            return
        self.security.static_linked = False

        off = self._rva_to_offset(import_rva)
        if off is None:
            return

        i = 0
        while True:
            desc_off = off + i * 20
            if desc_off + 20 > len(self.data):
                break
            orig_thunk, _ts, _fwd, name_rva, first_thunk = \
                self._u('IIIII', desc_off)
            if name_rva == 0 and orig_thunk == 0:
                break

            dll_name_off = self._rva_to_offset(name_rva)
            dll_name = (self._read_str(dll_name_off)
                        if dll_name_off is not None else f"<dll_{i}>")
            if dll_name and dll_name not in self.libraries:
                self.libraries.append(dll_name)

            thunk_rva = orig_thunk if orig_thunk else first_thunk
            thunk_off = self._rva_to_offset(thunk_rva)
            if thunk_off is None:
                i += 1
                continue

            j         = 0
            entry_sz  = 8 if self.bits == 64 else 4
            ord_flag  = (1 << 63) if self.bits == 64 else (1 << 31)

            while True:
                e_off = thunk_off + j * entry_sz
                if e_off + entry_sz > len(self.data):
                    break
                val = (self._u('Q', e_off)[0] if self.bits == 64
                       else self._u('I', e_off)[0])
                if val == 0:
                    break

                if val & ord_flag:
                    ordinal = int(val & 0xffff)
                    self.imports.append(ImportEntry(
                        name=f"#{ordinal}", dll=dll_name, ordinal=ordinal))
                else:
                    hint_off = self._rva_to_offset(int(val & 0x7fffffff))
                    if hint_off is not None and hint_off + 2 < len(self.data):
                        fn = self._read_str(hint_off + 2)
                        if fn:
                            self.imports.append(ImportEntry(name=fn, dll=dll_name))
                j += 1
            i += 1

    def _parse_exports(self):
        if len(self.data_dirs) < 1:
            return
        exp_rva, _ = self.data_dirs[0]
        if exp_rva == 0:
            return
        off = self._rva_to_offset(exp_rva)
        if off is None:
            return

        (_, _, _, _, _,
         base, num_funcs, num_names,
         funcs_rva, names_rva, ords_rva) = self._u('IIHIIIIIII', off)

        funcs_off = self._rva_to_offset(funcs_rva)
        names_off = self._rva_to_offset(names_rva)
        ords_off  = self._rva_to_offset(ords_rva)
        if None in (funcs_off, names_off, ords_off):
            return

        for i in range(num_names):
            try:
                name_ptr = self._u('I', names_off + i * 4)[0]
                ord_idx  = self._u('H', ords_off  + i * 2)[0]
                func_rva = self._u('I', funcs_off + ord_idx * 4)[0]
                name_off = self._rva_to_offset(name_ptr)
                fn       = (self._read_str(name_off)
                            if name_off else f"#ord{base + ord_idx}")
                self.exports.append(ExportEntry(
                    name=fn,
                    addr=self.image_base + func_rva,
                    ordinal=base + ord_idx,
                ))
            except (struct.error, TypeError):
                continue

    def _check_security(self):
        dc = self.dll_char
        self.security.nx           = bool(dc & PE.DLLCHAR_NX_COMPAT)
        self.security.aslr         = bool(dc & PE.DLLCHAR_DYNAMIC_BASE)
        self.security.high_entropy = bool(dc & PE.DLLCHAR_HIGH_ENTROPY_VA)
        self.security.cfg          = bool(dc & PE.DLLCHAR_GUARD_CF)
        self.security.seh          = not bool(dc & PE.DLLCHAR_NO_SEH)

        imp_names = {imp.name for imp in self.imports}
        self.security.canary = bool(
            {'__security_check_cookie', '__security_cookie',
             '__GSHandlerCheck'} & imp_names)

        if len(self.data_dirs) > 6:
            dbg_rva, _ = self.data_dirs[6]
            self.security.stripped = (dbg_rva == 0)

    def offset_to_vaddr(self, off: int) -> Optional[int]:
        for i in range(self.num_secs):
            tbl_off = self.sec_off + i * 40
            vsize, rva, raw_sz, raw_off = self._u('IIII', tbl_off + 8)
            span = raw_sz
            if raw_off and raw_off <= off < raw_off + span:
                return self.image_base + rva + (off - raw_off)
        return None

    @property
    def arch(self) -> str:
        # в”Җв”Җ FIX: uses PE.MACHINE_NAMES в”Җв”Җ
        return PE.MACHINE_NAMES.get(self.machine,
                                    f"Unknown(0x{self.machine:x})")

    @property
    def pe_type_str(self) -> str:
        if self.characteristics & 0x2000: return "DLL"
        if self.characteristics & 0x0002: return "EXE"
        return "Unknown"

    @property
    def subsystem_str(self) -> str:
        return PE.SUBSYSTEM.get(self.subsystem, f"Unknown({self.subsystem})")

    @property
    def compile_time(self) -> str:
        try:
            dt = datetime.fromtimestamp(self.timestamp, tz=timezone.utc)
            return dt.strftime('%Y-%m-%d %H:%M:%S UTC')
        except Exception:
            return f"0x{self.timestamp:08x}"


