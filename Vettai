def shannon_entropy(data: bytes) -> float:
    if not data:
        return 0.0
    freq = [0] * 256
    for b in data:
        freq[b] += 1
    length = len(data)
    return -sum(
        (f / length) * math.log2(f / length)
        for f in freq if f > 0
    )


def extract_strings(data: bytes, min_len: int = 5) -> List[Tuple[int, str]]:
    results, current, start = [], [], 0
    for i, byte in enumerate(data):
        if 0x20 <= byte <= 0x7e:
            if not current:
                start = i
            current.append(chr(byte))
        else:
            if len(current) >= min_len:
                results.append((start, ''.join(current)))
            current = []
    if len(current) >= min_len:
        results.append((start, ''.join(current)))
    return results


def extract_wide_strings(data: bytes, min_len: int = 4) -> List[Tuple[int, str]]:
    results, current, start = [], [], 0
    i = 0
    while i < len(data) - 1:
        lo, hi = data[i], data[i + 1]
        if hi == 0 and 0x20 <= lo <= 0x7e:
            if not current:
                start = i
            current.append(chr(lo))
            i += 2
        else:
            if len(current) >= min_len:
                results.append((start, ''.join(current)))
            current = []
            i += 1
    if len(current) >= min_len:
        results.append((start, ''.join(current)))
    return results


