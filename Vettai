#  XOR KEY DETECTOR
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

class XORDetector:
    @staticmethod
    def scan(sections: List[SectionInfo], data: bytes) -> List[dict]:
        results, seen_keys = [], set()
        for sec in sections:
            if not sec.executable or sec.size == 0:
                continue
            sd = data[sec.offset:sec.offset + sec.size]
            for i in range(len(sd) - 2):
                key, hint = None, ""
                if sd[i] == 0x80 and (sd[i+1] & 0x38) == 0x30:
                    key, hint = sd[i+2], "xor byte [mem], imm8"
                elif sd[i] == 0x34:
                    key, hint = sd[i+1], "xor al, imm8"
                elif sd[i] == 0x83 and sd[i+1] == 0xf0:
                    key, hint = sd[i+2], "xor eax, imm8"
                if key and key != 0 and key not in seen_keys:
                    seen_keys.add(key)
                    results.append({
                        'addr':      sec.vaddr + i,
                        'key':       key,
                        'printable': chr(key) if 0x20 <= key <= 0x7e else '?',
                        'hint':      hint,
                    })
                    if len(results) >= 8:
                        return results
        return results


