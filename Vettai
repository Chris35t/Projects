# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

class FlagCheckDetector:

    CHECK_FUNCS = {
        'strcmp', 'strncmp', 'memcmp', 'bcmp',
        'strcasecmp', 'strncasecmp', 'CRYPTO_memcmp',
        'lstrcmpA', 'lstrcmpW', 'lstrcmpiA', 'lstrcmpiW',
        'CompareStringA', 'CompareStringW',
        'EVP_DigestFinal', 'MD5_Final', 'SHA1_Final',
    }

    @classmethod
    def analyze_elf(cls, elf: ELFParser,
                    sus: List[SuspiciousString]) -> List[FlagCandidate]:
        candidates = []
        if elf.e_machine == ELF.EM_X86_64:
            candidates += cls._elf_x64(elf, sus)
        elif elf.e_machine == ELF.EM_386:
            candidates += cls._elf_x86(elf, sus)
        for sym in elf.get_named_funcs():
            if sym['hot'] and sym['value']:
                candidates.append(FlagCandidate(
                    addr=sym['value'],
                    reason=f"hot function: {sym['name']}"))
        return cls._dedup(candidates)

    @classmethod
    def analyze_pe(cls, pe: PEParser,
                   sus: List[SuspiciousString]) -> List[FlagCandidate]:
        candidates = []
        imp_names = {imp.name for imp in pe.imports}

        for fn in cls.CHECK_FUNCS & imp_names:
            candidates.append(FlagCandidate(
                addr=0, reason=f"imports comparison function: {fn}"))

        dangerous = PE.DANGEROUS & imp_names
        for d in dangerous:
            candidates.append(FlagCandidate(
                addr=0, reason=f"dangerous API: {d}"))

        flag_strs = [s for s in sus if s.category == "flag_hint"]
        for exp in pe.exports[:5]:
            if flag_strs:
                candidates.append(FlagCandidate(
                    addr=exp.addr,
                    reason=f"export near flag strings: {exp.name}"))

        return cls._dedup(candidates)

    @classmethod
    def _elf_x64(cls, elf: ELFParser,
                 sus: List[SuspiciousString]) -> List[FlagCandidate]:
        candidates = []
        text_sec = next((s for s in elf.sections if s.name == '.text'), None)
        if not text_sec:
            return candidates

        td   = elf.data[text_sec.offset:text_sec.offset + text_sec.size]
        base = text_sec.vaddr
        lea  = re.compile(b'\x48\x8d.(.{4})', re.DOTALL)
        call = re.compile(b'\xe8(.{4})',       re.DOTALL)

        for ss in [s for s in sus if s.vaddr]:
            for m in lea.finditer(td):
                ia   = base + m.start()
                disp = struct.unpack('<i', m.group(1))[0]
                if ia + len(m.group(0)) + disp == ss.vaddr:
                    fa = cls._prologue_x64(td, m.start(), base)
                    candidates.append(FlagCandidate(
                        addr=fa,
                        reason=f'references "{ss.content[:40]}"',
                        refs=[f"0x{ia:x}: lea вҶ’ 0x{ss.vaddr:x}"],
                    ))

        plt = elf.resolve_plt()
        for fn, plt_addr in plt.items():
            if fn not in cls.CHECK_FUNCS:
                continue
            for m in call.finditer(td):
                ia   = base + m.start()
                disp = struct.unpack('<i', m.group(1))[0]
                if ia + 5 + disp == plt_addr:
                    fa = cls._prologue_x64(td, m.start(), base)
                    candidates.append(FlagCandidate(
                        addr=fa, reason=f"calls {fn}",
                        refs=[f"0x{ia:x}: call {fn}@plt"],
                    ))
        return candidates

    @classmethod
    def _elf_x86(cls, elf: ELFParser,
                 sus: List[SuspiciousString]) -> List[FlagCandidate]:
        candidates = []
        text_sec = next((s for s in elf.sections if s.name == '.text'), None)
        if not text_sec:
            return candidates
        td   = elf.data[text_sec.offset:text_sec.offset + text_sec.size]
        base = text_sec.vaddr
        for ss in [s for s in sus if s.vaddr]:
            needle = b'\x68' + struct.pack('<I', ss.vaddr)
            idx = 0
            while True:
                pos = td.find(needle, idx)
                if pos == -1:
                    break
                fa = cls._prologue_x86(td, pos, base)
                candidates.append(FlagCandidate(
                    addr=fa,
                    reason=f'references "{ss.content[:40]}"',
                    refs=[f"0x{base + pos:x}: push 0x{ss.vaddr:x}"],
                ))
                idx = pos + 5
        return candidates

    @staticmethod
    def _prologue_x64(td: bytes, off: int, base: int) -> int:
        lim = max(0, off - 0x300)
        p   = off
        while p > lim:
            p -= 1
            if td[p] == 0x55 and td[p+1:p+4] == b'\x48\x89\xe5':
                return base + p
            if td[p:p+4] == b'\xf3\x0f\x1e\xfa':
                return base + p
            if td[p] == 0x55:
                return base + p
        return base + off

    @staticmethod
    def _prologue_x86(td: bytes, off: int, base: int) -> int:
        lim = max(0, off - 0x300)
        p   = off
        while p > lim:
            p -= 1
            if td[p] == 0x55 and td[p+1:p+3] == b'\x89\xe5':
                return base + p
        return base + off

    @staticmethod
    def _dedup(lst: List[FlagCandidate]) -> List[FlagCandidate]:
        seen, out = set(), []
        for c in lst:
            key = (c.addr, c.reason[:30])
            if key not in seen:
                seen.add(key)
                out.append(c)
        return out


