    def imports(imports: List[ImportEntry], fmt: str):
        Renderer.hdr("IMPORTS", "рҹ“Ҙ")
        if not imports:
            print(f"  {C.DIM}No imports (statically linked?){C.RST}")
            return

        check_f  = FlagCheckDetector.CHECK_FUNCS
        input_f  = PE.INPUT_FUNCS
        output_f = PE.OUTPUT_FUNCS

        def classify(n):
            if n in check_f:   return C.RED,     "вҡ”  comparison"
            if n in input_f:   return C.YELLOW,  "рҹ“Ҙ input"
            if n in output_f:  return C.CYAN,    "рҹ“Ө output"
            if n in PE.DANGEROUS: return C.RED,  "вҡ   DANGEROUS"
            if n in PE.CRYPTO: return C.MAGENTA, "рҹ”җ crypto"
            return C.DIM, ""

        if fmt == 'pe':
            by_dll: Dict[str, List[ImportEntry]] = {}
            for imp in imports:
                by_dll.setdefault(imp.dll, []).append(imp)
            for dll, entries in by_dll.items():
                print(f"\n  {C.BOLD}{C.MAGENTA}{dll}{C.RST}")
                for imp in entries:
                    col, tag = classify(imp.name)
                    print(f"    {col}{imp.name:<40}{C.RST} {C.DIM}{tag}{C.RST}")
        else:
            important, others = [], []
            for imp in imports:
                col, tag = classify(imp.name)
                if tag:
                    important.append((imp.name, col, tag))
                else:
                    others.append(imp.name)
            for name, col, tag in important:
                print(f"  {col}{name:<35}{C.RST} {C.DIM}{tag}{C.RST}")
            if others:
                print(f"\n  {C.DIM}Others: {', '.join(sorted(others))}{C.RST}")

    # в”Җв”Җ Exports в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def exports(exports: List[ExportEntry]):
        if not exports:
            return
        Renderer.hdr("EXPORTS", "рҹ“Ө")
        for exp in exports[:20]:
            print(f"  {C.GREEN}0x{exp.addr:x}{C.RST}  {exp.name}")
        if len(exports) > 20:
            print(f"  {C.DIM}вҖҰ and {len(exports) - 20} more{C.RST}")

    # в”Җв”Җ Named Functions (ELF) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def named_functions(elf: ELFParser):
        if elf.security.stripped:
            return
        Renderer.hdr("NAMED FUNCTIONS", "рҹ§©")
        funcs = elf.get_named_funcs()
        if not funcs:
            return
        for sym in funcs[:25]:
            col    = C.RED   if sym['hot'] else C.WHITE
            marker = "  рҹҺҜ"  if sym['hot'] else ""
            sz     = f"  sz:{sym['size']}" if sym['size'] else ""
            print(f"  {C.GREEN}0x{sym['value']:08x}{C.RST}  "
                  f"{col}{sym['name']}{C.RST}{C.DIM}{sz}{C.RST}{marker}")
        if len(funcs) > 25:
            print(f"  {C.DIM}вҖҰ {len(funcs) - 25} more{C.RST}")

    # в”Җв”Җ Flag Candidates в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def flag_candidates(cands: List[FlagCandidate]):
        Renderer.hdr("FLAG-CHECK CANDIDATES", "рҹҺҜ")
        if not cands:
            print(f"  {C.DIM}No flag-check patterns detected{C.RST}")
            return
        for fc in cands[:15]:
            addr = f"0x{fc.addr:x}" if fc.addr else "imported"
            print(f"\n  {C.RED}{C.BOLD}рҹҺҜ {addr}{C.RST}  {fc.reason}")
            for r in fc.refs:
                print(f"     {C.DIM}в””в”Җ {r}{C.RST}")

    # в”Җв”Җ XOR Keys в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def xor_keys(keys: List[dict]):
        if not keys:
            return
        Renderer.hdr("POTENTIAL XOR KEYS", "рҹ”‘")
        for k in keys:
            print(f"  {C.MAGENTA}0x{k['addr']:x}{C.RST}  "
                  f"key={C.YELLOW}0x{k['key']:02x}{C.RST} "
                  f"{C.DIM}('{k['printable']}')  {k['hint']}{C.RST}")

    # в”Җв”Җ Entropy в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def entropy(secs: List[SectionInfo]):
        anomalies = [(s.name, s.entropy) for s in secs if s.entropy > 6.2]
        if not anomalies:
            return
        Renderer.hdr("ENTROPY ANOMALIES", "рҹ“Ҡ")
        for name, ent in anomalies:
            bar   = "в–Ҳ" * int(ent * 3) + "в–‘" * (24 - int(ent * 3))
            col   = C.RED if ent > 7.5 else C.YELLOW
            label = "PACKED/ENCRYPTED" if ent > 7.5 else "HIGH ENTROPY"
            print(f"  {name:<18} {col}{bar} {ent:.2f}/8.0  {label}{C.RST}")

    # в”Җв”Җ Tips в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def tips(info: BinaryInfo,
             sec: SecurityFlags,
             cands: List[FlagCandidate],
             imports: List[ImportEntry],
             sus: List[SuspiciousString]):
        Renderer.hdr("HUNTER'S TIPS", "вҡЎ")
        tips = []
        fname = os.path.basename(info.filepath)

        if info.fmt == 'elf':
            if not sec.pie and cands:
                tips.append(f"{C.CYAN}GDB:{C.RST} {C.BOLD}b *0x{cands[0].addr:x}{C.RST}")
            if sec.pie:
                tips.append(f"{C.CYAN}GDB PIE:{C.RST} use "
                            f"{C.BOLD}info proc mappings{C.RST} for base addr")
            check_i = [i.name for i in imports
                       if i.name in ('strcmp','strncmp','memcmp')]
            if check_i:
                fn = check_i[0]
                tips.append(f"{C.CYAN}GDB:{C.RST} {C.BOLD}b {fn}{C.RST} "
                            f"вҶ’ {C.BOLD}x/s $rdi{C.RST} / {C.BOLD}x/s $rsi{C.RST}")
            if not sec.stripped:
                tips.append(f"{C.CYAN}Symbols:{C.RST} "
                            f"{C.BOLD}nm {fname} | grep -iE 'check|flag|verify'{C.RST}")
            if not sec.nx:
                tips.append(f"{C.RED}вҡ   NX disabled{C.RST} вҖ” shellcode injection possible")
            tips.append(f"{C.CYAN}ltrace:{C.RST} {C.BOLD}ltrace ./{fname}{C.RST}")
            tips.append(f"{C.CYAN}strace:{C.RST} {C.BOLD}strace ./{fname}{C.RST}")
        else:
            if not sec.aslr and cands and cands[0].addr:
                tips.append(f"{C.CYAN}x64dbg:{C.RST} "
                            f"{C.BOLD}bp 0x{cands[0].addr:x}{C.RST} (no ASLR)")
            elif sec.aslr:
                tips.append(f"{C.CYAN}x64dbg:{C.RST} ASLR on вҖ” use Module+offset")
            check_i = [i.name for i in imports
                       if i.name in ('strcmp','strncmp','lstrcmpA','lstrcmpW')]
            if check_i:
                tips.append(f"{C.CYAN}x64dbg:{C.RST} break on {C.BOLD}{check_i[0]}{C.RST}")
            dang = [i.name for i in imports if i.name in PE.DANGEROUS]
            if dang:
                tips.append(f"{C.RED}вҡ   Dangerous APIs:{C.RST} {', '.join(dang[:5])}")
            tips.append(f"{C.CYAN}Wide strings:{C.RST} "
                        f"{C.BOLD}strings -el {fname}{C.RST}")
            tips.append(f"{C.CYAN}DIE:{C.RST} run Detect-It-Easy for packer ID")

        fs = [s for s in sus
              if 'flag' in s.content.lower() or 'correct' in s.content.lower()]
        if fs and fs[0].vaddr:
            tips.append(f"{C.CYAN}Watch:{C.RST} memory BP at "
                        f"{C.BOLD}0x{fs[0].vaddr:x}{C.RST} (flag string)")

        print()
        for t in tips:
            print(f"  {C.BOLD}вҶ’{C.RST} {t}")
        print()

    # в”Җв”Җ Summary в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    @staticmethod
    def summary(info: BinaryInfo,
                sus: List[SuspiciousString],
                cands: List[FlagCandidate],
                imports: List[ImportEntry]):
        Renderer.hdr("HUNT SUMMARY", "рҹ©ё")
        flag_n   = sum(1 for s in sus if s.category == "flag_hint")
        crypto_n = sum(1 for s in sus if s.category == "crypto")
        check_i  = [i for i in imports if i.name in FlagCheckDetector.CHECK_FUNCS]

        print(f"  {C.BOLD}Flag-hint strings:{C.RST}  "
              f"{C.RED if flag_n else C.DIM}{flag_n}{C.RST}")
        print(f"  {C.BOLD}Crypto strings:{C.RST}     "
              f"{C.MAGENTA if crypto_n else C.DIM}{crypto_n}{C.RST}")
        print(f"  {C.BOLD}Check functions:{C.RST}    "
              f"{C.RED if check_i else C.DIM}"
              f"{len(check_i)} ({', '.join(set(i.name for i in check_i))}){C.RST}")
        print(f"  {C.BOLD}Flag candidates:{C.RST}    "
              f"{C.RED if cands else C.DIM}{len(cands)}{C.RST}")
        print()
        if cands:
            print(f"  {C.GREEN}{C.BOLD}Start here:{C.RST}")
            for fc in cands[:3]:
                addr = f"0x{fc.addr:x}" if fc.addr else "imported"
                print(f"    {C.RED}рҹҺҜ {addr}{C.RST}  вҖ”  {fc.reason}")
        print()


